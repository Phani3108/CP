# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=contractspulse

# API URLs used internally by Docker
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
REDIS_URL=redis://redis:6379/0

# --- LLM: Google Gemini via its OpenAI-compatible endpoint ---
OPENAI_API_KEY=your_gemini_api_key_here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_API_KEY=your_gemini_api_key_here

# pydantic-ai agent models (extraction / risk / redline verify / obligations)
OPENAI_MODEL_EXTRACTOR=openai:gemini-3.5-flash
OPENAI_MODEL_RISK=openai:gemini-3.5-flash
# Direct chat/assistant/email models
OPENAI_MODEL_CHAT=gemini-3.5-flash
OPENAI_MODEL_CHAT_FALLBACK=gemini-flash-latest
# Embeddings (dimensions must match the vector(1536) column)
OPENAI_EMBEDDING_MODEL=gemini-embedding-001
OPENAI_EMBEDDING_DIMENSIONS=1536

# Give the per-clause LLM pipeline room before heuristic-fallback timeout
CONTRACT_ANALYSIS_TIMEOUT_S=240

# Security & Signup Settings
DISABLE_SIGNUP=false
JWT_SECRET=super-secret-contractspulse-key-change-it
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
